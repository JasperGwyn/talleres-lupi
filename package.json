{
  "name": "talleres-lupi",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check-all": "npm run lint && npm run typecheck",
    "download-pdfs": "npx tsx scripts/download-pdfs.ts",
    "parse-talleres": "npx tsx scripts/parse-talleres.ts",
    "geocode-centros": "npx tsx scripts/geocode-centros.ts",
    "merge-data": "npx tsx scripts/merge-data.ts",
    "prepare-data": "npm run download-pdfs && npm run parse-talleres && npm run geocode-centros && npm run merge-data"
  },
  "dependencies": {
    "next": "^14.2.0",
    "pdf-parse": "^1.1.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^8.0.0",
    "eslint-config-next": "^14.2.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
